---
import TopBar from '../components/TopBar.astro';
import BottomBar from '../components/BottomBar.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Portfolio de Josep Company Cuesta, desarrollador full-stack especializado en Node.js, React y Astro. Explora mis proyectos y experiencia.',
  image = '/og-image.jpg',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://josepcompany.dev/';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const personalInfo = {
  name: 'Josep Company Cuesta',
  jobTitle: 'Desarrollador Web Full Stack',
  email: 'contacto@josepcompany.dev',
  github: 'https://github.com/Pepecc',
  linkedin: 'https://www.linkedin.com/in/josep-c-229b561b5/',
  skills: [
    'JavaScript',
    'React',
    'Astro',
    'Node.js',
    'TypeScript',
    'CSS',
    'Kubernetes',
    'Docker',
    'Azure',
    'SAP BTP',
    'CAP',
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <meta
      name="google-site-verification"
      content="-wRtHIZU5maj8GU8_Hwm-v4OrTvpO-FQbkeG1CowVdE"
    />
    <meta name="description" content={description} />
    <meta name="author" content={personalInfo.name} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Josep Company" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={new URL(image, siteUrl)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, siteUrl)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Josep Company</title>
    <ClientRouter />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: personalInfo.name,
        jobTitle: personalInfo.jobTitle,
        url: siteUrl,
        email: personalInfo.email,
        sameAs: [personalInfo.github, personalInfo.linkedin],
        knowsAbout: personalInfo.skills,
      })}
    />
  </head>
  <body>
    <TopBar />
    <main transition:animate="fade">
      <slot />
    </main>
    <BottomBar />
  </body>
</html>

<script is:inline>
  function applyAppTheme() {
    const getTheme = () => {
      if (localStorage.getItem('app-theme')) {
        return localStorage.getItem('app-theme') || '';
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    };

    const appTheme = getTheme();
    if (appTheme === 'dark') {
      document.documentElement.classList.add('dark');
    }

    const modeLabel = document.getElementById('theme-mode-label');
    if (modeLabel) {
      modeLabel.textContent = appTheme === 'dark' ? 'modo: oscuro' : 'modo: claro';
    }
  }

  applyAppTheme();

  document.addEventListener('astro:after-swap', applyAppTheme);
</script>

<style is:global>
  :root {
    --color-bg: #f3f3ef;
    --color-surface: #f3f3ef;
    --color-surface-header: hsl(60 8% 94% / 0.85);
    --color-surface-border: transparent;
    --color-text: #26251f;
    --color-text-secondary: #75726a;
    --color-border: #c6c3b6;
    --color-hover: #e9e6da;
    --color-primary: #996a00;
    --color-primary-hover: #26251f;
    --color-card-hover: #e9e6da;
    --color-code-bg: #e9e6da;
  }

  html.dark {
    --color-bg: #101418;
    --color-surface: #101418;
    --color-surface-header: hsl(210 20% 8% / 0.85);
    --color-surface-border: transparent;
    --color-text: #d6d3c6;
    --color-text-secondary: #848b92;
    --color-border: #2c333b;
    --color-hover: #1c232b;
    --color-primary: #e6a53c;
    --color-primary-hover: #f0ede1;
    --color-card-hover: #1c232b;
    --color-code-bg: #1c232b;
  }

  html.dark h1,
  html.dark h2 {
    color: #f0ede1;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    background-color: var(--color-surface);
    transition:
      background-color 0.3s,
      border-color 0.3s;
    font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.5px;
  }

  h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  h3 {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-text-secondary);
  }

  p,
  li {
    font-size: 0.85rem;
    line-height: 1.8;
  }

  a {
    text-decoration: none;
  }

  .main-container a {
    color: var(--color-primary);
  }

  .main-container a:hover {
    color: var(--color-primary-hover);
  }

  code {
    background: var(--color-code-bg);
    padding: 1px 5px;
    font-size: inherit;
  }

  @media (max-width: 500px) {
    li {
      font-size: 0.8rem;
    }
    p {
      font-size: 0.8rem;
    }

    h1 {
      font-size: 1.35rem;
    }

    h2 {
      font-size: 1rem;
    }

    nav li {
      font-size: 0.85rem;
    }

    span {
      font-size: 0.85rem;
    }

    body {
      padding-left: 0.4rem;
      padding-right: 1rem;
    }
  }
</style>
