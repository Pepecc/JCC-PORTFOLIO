const projects = [
  {
    name: 'RaspiWeather',
    description: [
      'RaspiWeather es el proyecto de una estación meteorológica casera utilizando una Raspberry Pi. Está conectada a un sensor que registra la temperatura y la humedad cada 30 minutos de forma automática. Cada medición se envía a la nube, donde queda almacenada y disponible para una aplicación web desde la que se puede consultar tanto los datos actuales como su evolución a lo largo del tiempo.',
      'Además de mostrar la información recogida por el sensor, el dashboard calcula la sensación térmica y representa los datos diferenciando las horas de día y de noche para facilitar su interpretación.',
      'Este es un proyecto que sigo ampliando poco a poco. Para la siguiente versión, mi idea es incorporar un nuevo sensor de presión atmosférica y una cámara.',
    ],
    stack: ['python', 'raspberrypi', 'react', 'vite', 'firebase'],
    links: [
      {
        icon: 'web',
        label: 'Enlace a la web del dashboard',
        href: 'https://raspiweather-62c60.web.app/',
      },
      {
        icon: 'github',
        label: 'Enlace al repositorio del backend',
        href: 'https://github.com/Pepecc/RaspiWeather-Station',
      },
      {
        icon: 'github',
        label: 'Enlace al repositorio del frontend',
        href: 'https://github.com/Pepecc/RaspiWeather-Dashboard',
      },
    ],
  },
  {
    name: 'Mi portfolio',
    description: [
      'Mi portfolio personal, desarrollado con Astro y diseñado con un estilo minimalista para mostrar mis proyectos y las tecnologías con las que trabajo.', 
      'Esta web es rápida y responsive y además tiene modo claro/oscuro.',
    ],
    stack: ['astro', 'typescript', 'css'],
    links: [
      {
        icon: 'web',
        label: 'Enlace a la página... que es la misma que estás visitando',
        href: 'https://jcc-dev.onrender.com/',
      },
      {
        icon: 'github',
        label: 'Enlace al repositorio',
        href: 'https://github.com/Pepecc/JCC-PORTFOLIO',
      },
    ],
  },
  {
    name: 'Nexus AI',
    description: [
      'Desarrollo full-stack de una aplicación web con frontend en React y backend en NodeJS que integra APIs de modelos de lenguaje avanzados para generar respuestas y ofrecer funcionalidades inteligentes orientadas al usuario.',
      'En esta primera versión, se ofrecen los modelos 4o de OpenAI ChatGPT y Deep Seek Reasoner.',
    ],
    stack: ['react', 'typescript', 'redux', 'nodejs', 'express', 'firebase', 'docker'],
    note: 'Nota: este proyecto se encuentra completado al 85%, por este motivo, el enlace a la aplicación todavía no está disponible.',
    links: [
      {
        icon: 'web',
        label: 'Enlace a la aplicación',
      },
      {
        icon: 'github',
        label: 'Enlace al repositorio del frontend',
        href: 'https://github.com/Pepecc/MSFE-DEEPSEEK-INTEGRATION',
      },
      {
        icon: 'github',
        label: 'Enlace al repositorio del backend',
        href: 'https://github.com/Pepecc/MSBE-DEEPSEEK-INTEGRATION',
      },
    ],
  },
] satisfies {
  name: string;
  description: string[];
  stack: (keyof typeof stackIcons)[];
  note?: string;
  links: { icon: keyof typeof iconPaths; label: string; href?: string }[];
}[];
---

<Layout
  title="Mis proyectos"
  description="Explora los proyectos web desarrollados por Josep Company Cuesta. Aplicaciones con React, Astro y Node.js"
  image="/og-image.jpg"
>
  <section>
    <div class="main-container">
      <h1>Mis proyectos</h1>
      <br />
      {
        projects.map((project) => (
          <article class="project-card">
            <h2>{project.name}</h2>
            {project.description.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
            {project.note && (
              <p>
                <em>{project.note}</em>
              </p>
            )}
            <h3 class="stack-title">Stack</h3>
            <ul class="stack-list">
              {project.stack.map((tech) => (
                <li class="stack-item">
                  <svg
                    aria-hidden="true"
                    class="stack-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path d={stackIcons[tech].path} />
                  </svg>
                  {stackIcons[tech].label}
                </li>
              ))}
            </ul>
            <div class="links-container">
              {project.links.map((link) =>
                link.href ? (
                  <a
                    class="link"
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg
                      aria-hidden="true"
                      class="bottom-icons"
                      xmlns="http://www.w3.org/2000/svg"
                      width="25"
                      height="25"
                      fill="#000000"
                      viewBox="0 0 256 256"
                    >
                      <path d={iconPaths[link.icon]} />
                    </svg>
                    {link.label}
                  </a>
                ) : (
                  <span class="link-disabled">
                    <svg
                      aria-hidden="true"
                      class="bottom-icons-disabled"
                      xmlns="http://www.w3.org/2000/svg"
                      width="25"
                      height="25"
                      fill="darkgrey"
                      viewBox="0 0 256 256"
                    >
                      <path d={iconPaths[link.icon]} />
                    </svg>
                    {link.label}
                  </span>
                )
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <style>
    .main-container {
      margin-left: auto;
      margin-right: auto;
      max-width: 750px;
      min-height: 100vh;
      padding-bottom: 6rem;
      box-sizing: border-box;
      background-color: var(--color-surface);
      transition:
        background-color 0.3s,
        border-color 0.3s;
      color: var(--color-text);
    }
    .project-card {
      margin-bottom: 2rem;
    }
    .stack-title {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }
    .stack-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.25rem;
      list-style: none;
      margin: 0 0 1.25rem;
      padding: 0;
    }
    .stack-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.9rem;
    }
    .links-container {
      display: flex;
      flex-direction: column;
    }

    .link,
    .link-disabled {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      cursor: pointer;
    }

    .bottom-icons-disabled,
    .link-disabled {
      pointer-events: none;
      color: darkgrey;
    }

    .bottom-icons:hover {
      fill: var(--color-text-secondary);
    }
    .link:hover {
      color: var(--color-text-secondary);
    }

    :global(html.dark) .bottom-icons {
      fill: var(--color-text);
    }

    :global(html.dark) .bottom-icons:hover {
      fill: var(--color-text-secondary);
    }

    a {
      text-decoration: none;
      color: var(--color-text);
    }

    @media (max-width: 500px) {
      .link,
      .link-disabled,
      .stack-item {
        font-size: 0.85rem;
      }
    }
  </style>
</Layout>
