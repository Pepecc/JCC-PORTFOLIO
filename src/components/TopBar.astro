---
import ThemeToggle from './ThemeToggle.astro';
const navigationItems = [
  { number: '01', label: 'sobre-mi', href: '/' },
  { number: '02', label: 'mi-trabajo', href: '/my-work/' },
  { number: '03', label: 'mis-proyectos', href: '/my-projects/' },
];
const currentPath = Astro.url.pathname;
---

<header id="container">
  <div class="container-top-items">
    <div class="molino-circle">
      <a href="/" aria-label="Inicio" class="logo-link">
        <svg
          aria-hidden="true"
          id="molinux"
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          fill="#000000"
          viewBox="0 0 256 256"
        >
          <path
            d="M224,224H182.94l-6.3-44.12,3.24,1.91a16,16,0,0,0,21.91-5.67l12-20.34a16,16,0,0,0-5.67-21.91l-35-20.61,40.69-69.13a16,16,0,0,0-5.67-21.91l-20.34-12a16,16,0,0,0-21.91,5.67l-20.61,35L76.12,10.22a16,16,0,0,0-21.91,5.67l-12,20.33a16,16,0,0,0,5.67,21.92l35,20.61L42.21,147.88a16,16,0,0,0,5.67,21.91l20.34,12a15.57,15.57,0,0,0,10.58,2L73.06,224H32a8,8,0,0,0,0,16H224a8,8,0,0,0,0-16Zm-24-76.34L188,168l-69.13-40.69,12-20.35ZM179.66,24,200,36l-40.69,69.14L139,93.17ZM56,44.35,68,24,137.14,64.7l-12,20.35ZM76.34,168,56,156,96.69,86.86l20.36,12Zm12.88,56L98,162.8l12.77-21.7L159,169.5l7.79,54.5Z"
          >
          </path>
        </svg>
        <span class="logo-text">jcc</span>
      </a>
    </div>
    <div class="right-top-items">
      <nav class="navigation-header">
        <ul>
          {
            navigationItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={currentPath === item.href ? 'page' : undefined}
                >
                  <span class="nav-number">{item.number}</span> {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  #container {
    font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
    position: sticky;
    top: 0;
    backdrop-filter: blur(12px);
    background-color: var(--color-surface-header);
    transition:
      background-color 0.3s,
      border-color 0.3s;
    color: var(--color-text);
    z-index: 10;
    border-bottom: 1px dashed var(--color-border);
  }

  .right-top-items {
    display: flex;
    gap: 0.5rem;
  }

  .container-top-items {
    margin-left: auto;
    margin-right: auto;
    max-width: 750px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .molino-circle {
    padding: 0.5rem;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .logo-text {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
  }

  :global(html.dark) #molinux {
    fill: var(--color-primary);
  }
  nav ul {
    display: flex;
    list-style-type: none;
    gap: 1rem;
  }
  nav li {
    display: inline;
  }

  a {
    text-decoration: none;
    color: var(--color-text);
  }
  a:hover {
    color: var(--color-primary-hover);
  }

  .nav-number {
    color: var(--color-border);
  }

  nav a[aria-current='page'] {
    font-weight: 600;
    color: var(--color-text);
  }

  nav a[aria-current='page'] .nav-number {
    color: var(--color-primary);
  }

  :global(html.dark) a:hover {
    color: var(--color-primary-hover);
  }
</style>
